{
  "name": "duckpiper",
  "displayName": "DuckPiper",
  "description": "Local-first SQL, DuckDB notebooks, and pipelines in VS Code.",
  "publisher": "duckpiper",
  "icon": "media/icon.png",
  "author": "Rob Darling",
  "repository": {
    "type": "git",
    "url": "https://github.com/duckpiper/duckpiper.git"
  },
  "bugs": {
    "url": "https://github.com/duckpiper/duckpiper/issues"
  },
  "homepage": "https://duckpiper.com",
  "keywords": [
    "vscode",
    "vscode-extension",
    "sql",
    "duckdb",
    "postgres",
    "mysql",
    "database",
    "data-pipeline",
    "etl",
    "analytics",
    "data-engineering",
    "notebook",
    "lineage",
    "erd",
    "ai"
  ],
  "version": "1.3.0",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Data Science",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:postgres",
    "onNotebook:dp-notebook"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "notebooks": [
      {
        "type": "dp-notebook",
        "displayName": "Transformation Notebook",
        "selector": [
          {
            "filenamePattern": "*.dpnb"
          }
        ],
        "priority": "default"
      }
    ],
    "keybindings": [
      {
        "command": "dp.query.run",
        "key": "shift+cmd+r",
        "when": "editorTextFocus && resourceLangId == sql"
      },
      {
        "command": "dp.query.runCurrentStatement",
        "key": "shift+cmd+enter",
        "when": "editorTextFocus && resourceLangId == sql"
      }
    ],
    "commands": [
      {
        "command": "dp.actionsMenu",
        "title": "DuckPiper: Actions"
