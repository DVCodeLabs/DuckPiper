    "configuration": {
      "title": "DuckPiper",
      "properties": {
        "dp.query.maxRowsLimit": {
          "type": "number",
          "default": 10000,
          "minimum": 0,
          "description": "DuckPiper: Hard LIMIT for rows returned by SELECT queries. Set to 0 for no LIMIT. Use the 'Run (no LIMIT)' button in an sql file to bypass this setting."
        },
        "dp.results.editing.enabled": {
          "type": "boolean",
          "default": true,
          "description": "DuckPiper: Enable inline editing and save-back in resultsets when connection and result safety checks allow it."
        },
        "dp.ai.backend": {
          "type": "string",
          "enum": [
            "none",
            "extensionManaged",
            "vscodeChatModel",
            "openai",
            "anthropic",
            "azureOpenAI",
            "ollama",
            "openaiCompatible"
          ],
          "default": "",
          "enumDescriptions": [
            "Disable AI features. Use Copy Prompt for manual fallback.",
            "Use the extension-managed agent panel configuration.",
            "Use VS Code Language Model / chat model providers.",
            "Use OpenAI API directly.",
            "Use Anthropic API directly.",
            "Use Azure OpenAI API directly.",
            "Use a local Ollama instance.",
            "Use any OpenAI-compatible API endpoint."
          ],
          "markdownDescription": "DuckPiper: AI provider for all AI features. Leave empty for auto-detection based on your IDE. `extensionManaged` uses the agent panel. `vscodeChatModel` uses VS Code Language Models. Direct API providers require model and endpoint configuration."
        },
        "dp.ai.provider": {
          "type": "string",
          "enum": [
            "none",
            "vscode",
            "openai",
            "anthropic",
            "azureOpenAI",
            "ollama",
            "openaiCompatible"
          ],
          "default": "vscode",
          "description": "DuckPiper: AI provider selection.",
          "markdownDeprecationMessage": "**Deprecated:** Use `#dp.ai.backend#` instead. This setting will be auto-migrated on next activation.",
          "deprecationMessage": "Deprecated: Use dp.ai.backend instead."
        },
        "dp.ai.model": {
          "type": "string",
          "default": "gpt-4o",
          "markdownDescription": "DuckPiper: Model name (provider-specific). Use command [DP: Select AI Model](command:dp.ai.selectModel) to choose from all active VS Code models."
        },
        "dp.ai.endpoint": {
          "type": "string",
          "default": "",
          "description": "DuckPiper: Custom endpoint for openaiCompatible or local providers."
        },
        "dp.ai.sendSchemaContext": {
          "type": "boolean",
          "default": true,
          "description": "DuckPiper: Include schema + meta + relationships in AI prompts."
        },
        "dp.ai.maxSchemaChars": {
          "type": "number",
          "default": 150000,
          "minimum": 1000,
          "description": "DuckPiper: Approximate cap for schema context payload size (characters)."
        },
        "dp.ui.showRoutines": {
          "type": "boolean",
          "default": true,
          "description": "DuckPiper: Show procedures and functions in the Explorer when introspection metadata is available."
        },
        "dp.ui.showRoutineParameters": {
          "type": "boolean",
          "default": true,
          "description": "DuckPiper: Show routine signature details (parameters) in the Explorer label/tooltip when available."
        },
        "dp.system.overwriteByDefault": {
          "type": "boolean",
          "default": true,
          "description": "DuckPiper: If true, overwrites existing system tables without prompting (unless specified otherwise)."
        },
        "dp.system.maxRows": {
          "type": "number",
          "default": 100000,
          "description": "DuckPiper: Maximum number of rows to save to system table from a query."
        },
        "dp.duckdb.path": {
          "type": "string",
          "default": "dp/system/piper.duckdb",
          "description": "DuckPiper: Path to the local DuckDB transformation engine file (relative to workspace root)."
        },
        "dp.transform.previewRows": {
          "type": "number",
          "default": 200,
          "description": "DuckPiper: Number of rows to preview after running a transformation cell."
        },
        "dp.sqlCodelens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "DuckPiper: Show DuckPiper actions and connection selector at the top of SQL files."
        },
        "dp.format.enabled": {
          "type": "boolean",
          "default": true,
          "description": "DuckPiper: Enable SQL formatting features."
        },
        "dp.format.indentSize": {
          "type": "number",
          "default": 2,
          "description": "DuckPiper: Number of spaces to use for indentation."
        },
        "dp.format.keywordCase": {
          "type": "string",
          "enum": [
            "upper",
            "lower",
            "preserve"
          ],
          "default": "upper",
          "description": "DuckPiper: Case for SQL keywords."
        },
        "dp.format.dialectFallback": {
          "type": "string",
          "enum": [
            "postgresql",
            "mysql",
            "sql"
          ],
          "default": "sql",
          "description": "DuckPiper: Fallback dialect to use if no active connection is selected."
        }
      }
    },
